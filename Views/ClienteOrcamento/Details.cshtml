@model AfReparosAutomotivos.Models.OrcamentosViewModel

@{
    ViewData["Title"] = "Orcamento";
    var chaveAcesso = ViewBag.ChaveAcesso as string ?? string.Empty;
    var statusTexto = Model.status switch
    {
        2 => "Aprovado",
        3 => "Recusado",
        4 => "Sendo executado",
        5 => "Finalizado",
        _ => "Em analise"
    };
}

<div class="container mt-5">
    <div class="card shadow-lg border-0">
        <div class="card-header text-white" style="background-color: #3b2e1a">
            <h3 class="mb-0">Orcamento @Model.idOrcamento</h3>
        </div>

        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Cliente</dt>
                <dd class="col-sm-8">@Model.nome</dd>

                <dt class="col-sm-4">Documento</dt>
                <dd class="col-sm-8">@Model.DocumentoCli</dd>

                <dt class="col-sm-4">Veiculo</dt>
                <dd class="col-sm-8">@Model.Marca @Model.Modelo - @Model.Placa</dd>

                <dt class="col-sm-4">Cor</dt>
                <dd class="col-sm-8">@Model.Cor</dd>

                <dt class="col-sm-4">Ano</dt>
                <dd class="col-sm-8">@Model.Ano</dd>

                <dt class="col-sm-4">Data</dt>
                <dd class="col-sm-8">@Model.dataCriacao.ToString("dd/MM/yyyy")</dd>

                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8 fw-bold">@statusTexto</dd>

                <dt class="col-sm-4">Forma de pagamento</dt>
                <dd class="col-sm-8">@Model.formaPagamento</dd>

                <dt class="col-sm-4">Total</dt>
                <dd class="col-sm-8 fw-bold">@Model.total.ToString("C2")</dd>
            </dl>

            @if (Model.ServicosAssociados.Any())
            {
                <h4 class="mt-4">Servicos</h4>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Servico</th>
                            <th>Quantidade</th>
                            <th>Valor</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var servico in Model.ServicosAssociados)
                        {
                            <tr>
                                <td>@servico.descricao</td>
                                <td>@servico.qtd</td>
                                <td>@servico.preco.ToString("C2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="card-footer d-flex justify-content-end gap-2">
            <a asp-action="ClienteOrcamentos" class="btn btn-outline-secondary">Voltar</a>
            <a asp-action="ClienteOrcamentoPdf"
               asp-route-id="@Model.idOrcamento"
               asp-route-chave="@chaveAcesso"
               class="btn btn-danger">
                Baixar PDF
            </a>

            @if (Model.status == 1)
            {
                <form asp-action="ClienteOrcamentoStatus" method="post">
                    <input type="hidden" name="id" value="@Model.idOrcamento" />
                    <input type="hidden" name="chave" value="@chaveAcesso" />
                    <input type="hidden" name="decisao" value="aprovar" />
                    <button type="submit" class="btn btn-success">Aprovar</button>
                </form>

                <form asp-action="ClienteOrcamentoStatus" method="post">
                    <input type="hidden" name="id" value="@Model.idOrcamento" />
                    <input type="hidden" name="chave" value="@chaveAcesso" />
                    <input type="hidden" name="decisao" value="recusar" />
                    <button type="submit" class="btn btn-outline-secondary">Recusar</button>
                </form>
            }
        </div>
    </div>
</div>
