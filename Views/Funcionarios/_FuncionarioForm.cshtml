@model AfReparosAutomotivos.Models.Funcionarios

@{
    var isEdit = string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), "Edit", StringComparison.OrdinalIgnoreCase);
}

<div class="container mt-5">
    <div class="card shadow-lg rounded-4 border-0">
        <div class="card-header text-white text-center rounded-top-4" style="background-color: #3b2e1a">
            <h3 class="mb-0">@ViewData["Title"]</h3>
        </div>
        <div class="card-body p-4">
            <form asp-action="@ViewContext.RouteData.Values["action"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="idFuncionario" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Nome" class="form-label fw-semibold"></label>
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="celular" class="form-label fw-semibold">Celular</label>
                        <input asp-for="celular" class="form-control" />
                        <span asp-validation-for="celular" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="tipo_doc" class="form-label fw-semibold"></label>
                        <select asp-for="tipo_doc" class="form-select">
                            <option value="F">CPF</option>
                            <option value="J">CNPJ</option>
                        </select>
                        <span asp-validation-for="tipo_doc" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="documento" class="form-label fw-semibold">Documento</label>
                        <input asp-for="documento" class="form-control" />
                        <span asp-validation-for="documento" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="usuario" class="form-label fw-semibold"></label>
                        <input asp-for="usuario" class="form-control" maxlength="16" />
                        <span asp-validation-for="usuario" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="senha" class="form-label fw-semibold"></label>
                        <input asp-for="senha" type="password" class="form-control" maxlength="15" autocomplete="new-password" />
                        @if (isEdit)
                        {
                            <small class="text-muted">Deixe em branco para manter a senha atual.</small>
                        }
                        <span asp-validation-for="senha" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="permissao" class="form-label fw-semibold"></label>
                        <select asp-for="permissao" class="form-select">
                            <option value="1">Gerente</option>
                            <option value="2">Escrita</option>
                            <option value="3">Leitura</option>
                        </select>
                        <span asp-validation-for="permissao" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="statusFunc" class="form-label fw-semibold"></label>
                        <select asp-for="statusFunc" class="form-select">
                            <option value="1">Ativo</option>
                            <option value="2">Inativo</option>
                        </select>
                        <span asp-validation-for="statusFunc" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                    <button type="submit" class="btn-login">
                        <i class="fas fa-save"></i> Salvar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
