@model AfReparosAutomotivos.Models.Funcionarios

@{
    ViewData["Title"] = "Detalhes do Funcionário";
}

<div class="container mt-5">
    <div class="card shadow-lg rounded-4 border-0">
        <div class="card-header text-white text-center rounded-top-4" style="background-color: #3b2e1a">
            <h3 class="mb-0">Detalhes do Funcion&aacute;rio</h3>
        </div>
        <div class="card-body p-4">
            <dl class="row g-3">
                <dt class="col-sm-4">ID</dt>
                <dd class="col-sm-8">@Model.idFuncionario</dd>
                <dt class="col-sm-4">Funcion&aacute;rio</dt>
                <dd class="col-sm-8">@Model.Nome</dd>
                <dt class="col-sm-4">Celular</dt>
                <dd class="col-sm-8">@Model.celular</dd>
                <dt class="col-sm-4">Documento</dt>
                <dd class="col-sm-8">@Model.documento</dd>
                <dt class="col-sm-4">Tipo documento</dt>
                <dd class="col-sm-8">@(Model.tipo_doc == "J" ? "CNPJ" : "CPF")</dd>
                <dt class="col-sm-4">Usu&aacute;rio</dt>
                <dd class="col-sm-8">@Model.usuario</dd>
                <dt class="col-sm-4">Permiss&atilde;o</dt>
                <dd class="col-sm-8">@PermissaoTexto(Model.permissao)</dd>
                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8">@(Model.statusFunc == 1 ? "Ativo" : "Inativo")</dd>
            </dl>
        </div>
        <div class="card-footer bg-light border-0 pt-3 pb-4 d-flex justify-content-end gap-3">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="fas fa-arrow-left"></i> Voltar
            </a>
            <a asp-action="Edit" asp-route-id="@Model.idFuncionario" class="btn-login px-4">
                <i class="fas fa-pencil-alt"></i> Editar
            </a>
        </div>
    </div>
</div>

@functions {
    private static string PermissaoTexto(int permissao)
    {
        return permissao switch
        {
            1 => "Gerente",
            2 => "Escrita",
            3 => "Leitura",
            _ => "Nao informado"
        };
    }
}
