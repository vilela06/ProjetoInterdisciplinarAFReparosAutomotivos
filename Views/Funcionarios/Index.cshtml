@model IEnumerable<AfReparosAutomotivos.Models.Funcionarios>

@{
    ViewData["Title"] = "Funcionarios";
    var pesquisa = (ViewBag.Pesquisa as string) ?? string.Empty;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-end gap-3 mb-3">
        <h3 class="mb-0">Funcion&aacute;rios</h3>
        <div class="d-flex flex-column align-items-end gap-2">
            <a asp-action="Create" class="btn btn-primary fw-semibold">Novo Funcion&aacute;rio</a>
            <form asp-action="Index" method="get" class="d-flex" style="width: 360px; max-width: 100%;">
                <input type="text"
                       name="pesquisa"
                       value="@pesquisa"
                       class="form-control"
                       placeholder="Buscar por id, nome ou usuario" />
                <button type="submit" class="btn btn-primary ms-2" aria-label="Pesquisar funcionario">
                    <i class="fas fa-search"></i>
                </button>
                @if (!string.IsNullOrWhiteSpace(pesquisa))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2" aria-label="Limpar busca">
                        <i class="fas fa-times"></i>
                    </a>
                }
            </form>
        </div>
    </div>

    <table class="table table-striped table-hover rounded-3 overflow-hidden shadow-sm">
        <thead>
            <tr class="table-primary">
                <th>ID</th>
                <th>Funcion&aacute;rio</th>
                <th>Celular</th>
                <th>Documento</th>
                <th>Usu&aacute;rio</th>
                <th>Permiss&atilde;o</th>
                <th>Status</th>
                <th class="text-end">A&ccedil;&otilde;es</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.idFuncionario</td>
                    <td>@item.Nome</td>
                    <td>@item.celular</td>
                    <td>@item.documento</td>
                    <td>@item.usuario</td>
                    <td>@PermissaoTexto(item.permissao)</td>
                    <td>@(item.statusFunc == 1 ? "Ativo" : "Inativo")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.idFuncionario" class="btn btn-sm" title="Ver">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.idFuncionario" class="btn btn-sm" title="Editar">
                            <i class="fas fa-pencil-alt"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@functions {
    private static string PermissaoTexto(int permissao)
    {
        return permissao switch
        {
            1 => "Gerente",
            2 => "Escrita",
            _ => "Leitura"
        };
    }
}
