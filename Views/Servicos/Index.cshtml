@model List<AfReparosAutomotivos.Models.Servicos>

@{
    ViewData["Title"] = "Lista de Servicos";
    var pesquisa = (ViewBag.Pesquisa as string) ?? string.Empty;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center gap-3 mt-5 mb-3">
        <h3 class="mb-0">Servicos</h3>
        <form asp-action="Index" method="get" class="af-admin-search">
            <input type="text"
                   name="pesquisa"
                   value="@pesquisa"
                   placeholder="Buscar por id orcamento ou funcionario" />
            <button type="submit" aria-label="Pesquisar servico">
                <i class="fas fa-search"></i>
            </button>
            @if (!string.IsNullOrWhiteSpace(pesquisa))
            {
                <a asp-action="Index" class="af-filter-clear" aria-label="Limpar busca">
                    <i class="fas fa-times"></i>
                </a>
            }
        </form>
    </div>

    <table class="table table-striped table-hover rounded-3 overflow-hidden shadow-sm">
        <thead>
            <tr class="table-primary">
                <th class="text-left fw-semibold" scope="col">ID Orcamento</th>
                <th class="text-left fw-semibold" scope="col">@Html.DisplayNameFor(model => model.First().Descricao)</th>
                <th class="text-left fw-semibold" scope="col">@Html.DisplayNameFor(model => model.First().PrecoBase)</th>
                <th class="text-left fw-semibold" scope="col">@Html.DisplayNameFor(model => model.First().FuncionarioResponsavel)</th>
                <th class="text-left fw-semibold" scope="col">@Html.DisplayNameFor(model => model.First().Status)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.IdOrcamento?.ToString() ?? "-")</td>
                    <td>@Html.DisplayFor(modelItem => item.Descricao)</td>
                    <td>@item.PrecoBase.ToString("C")</td>
                    <td>@Html.DisplayFor(modelItem => item.FuncionarioResponsavel)</td>
                    <td>@Html.DisplayFor(modelItem => item.Status)</td>
                </tr>
            }
        </tbody>
    </table>
</div>
