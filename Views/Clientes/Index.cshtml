@model List<AfReparosAutomotivos.Models.Clientes>


@{
    ViewData["Title"] = "Lista de Clientes";
    var currentBusca = Context.Request.Query["busca"].ToString();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center gap-3 mt-5 mb-3">
        <h3 class="mb-0">Clientes (@(Model?.Count ?? 0))</h3>
        <form method="get" asp-action="Index" class="af-admin-search">
            <input type="text"
                   name="busca"
                   value="@currentBusca"
                   placeholder="Buscar por id ou nome" />
            <button type="submit" aria-label="Pesquisar cliente">
                <i class="fas fa-search"></i>
            </button>
            @if (!string.IsNullOrWhiteSpace(currentBusca))
            {
                <a asp-action="Index" class="af-filter-clear" aria-label="Limpar busca">
                    <i class="fas fa-times"></i>
                </a>
            }
        </form>
    </div>

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped table-hover rounded-3 overflow-hidden shadow-sm">
            <thead>
                <tr class="table-primary">
                    <th class="text-left fw-semibold" scope="col">@Html.DisplayNameFor(model => model.First().id)</th>
                    <th class="text-left fw-semibold" scope="col">Cliente</th>
                    <th class="text-left fw-semibold" scope="col">Documento</th>
                    <th class="text-left fw-semibold" scope="col">Celular</th>
                    <th class="text-left fw-semibold" scope="col">E-mail</th>
                    <th class="text-left fw-semibold" scope="col">Chave</th>
                    <th class="text-left fw-semibold" scope="col">Endereço</th>
                    <th class="text-end fw-semibold" scope="col">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.id)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.nome)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.documento)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.celular)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.email)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.chaveCli)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.endereco)
                        </td>
                        
                        <td class="text-end text-nowrap">
                            <div class="d-inline-flex align-items-center gap-2">
                                <a asp-action="Details" asp-route-id="@item.id" class="btn btn-sm btn-info text-white" title="Ver">
                                    <i class="fas fa-eye"></i>
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.id" class="btn btn-sm btn-warning text-dark" title="Editar">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info text-center mt-5" role="alert">
            Nenhum cliente encontrado.
        </div>
    }
</div>
