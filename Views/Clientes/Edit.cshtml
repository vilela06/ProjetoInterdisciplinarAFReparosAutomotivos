@model AfReparosAutomotivos.Models.Clientes

@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="container mt-5">
    <div class="card shadow-lg rounded-4 border-0">
        <div class="card-header text-white text-center rounded-top-4" style="background-color: #3b2e1a">
            <h3 class="mb-0">Editar Cliente</h3>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="id" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="nome" class="form-label fw-semibold">Nome</label>
                        <input asp-for="nome" type="text" class="form-control" value="@(Model?.nome)" pattern="^[^\d]+$" title="Nao use numeros no nome." required>
                        <span asp-validation-for="nome" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="documento" class="form-label fw-semibold">CPF/CNPJ</label>
                        <input asp-for="documento" type="text" class="form-control" value="@(Model?.documento)" maxlength="18" readonly>
                        <span asp-validation-for="documento" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="telefone" class="form-label fw-semibold">Telefone</label>
                        <input asp-for="telefone" type="text" class="form-control" value="@(Model?.telefone)" maxlength="14" inputmode="tel" pattern="^[0-9()\-\s]*$" title="Use apenas numeros, espacos, parenteses ou hifen.">
                        <span asp-validation-for="telefone" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="celular" class="form-label fw-semibold">Celular <span class="text-danger">*</span></label>
                        <input asp-for="celular" type="text" class="form-control" value="@(Model?.celular)" maxlength="15" inputmode="tel" pattern="^[0-9()\-\s]+$" title="Use apenas numeros, espacos, parenteses ou hifen." required>
                        <span asp-validation-for="celular" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="email" class="form-label fw-semibold">E-mail</label>
                        <input asp-for="email" type="email" class="form-control" value="@(Model?.email)" maxlength="50" required>
                        <span asp-validation-for="email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="chaveCli" class="form-label fw-semibold">Chave do cliente</label>
                        <input asp-for="chaveCli" type="text" class="form-control" value="@(Model?.chaveCli)" readonly>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="endereco" class="form-label fw-semibold">Endereço</label>
                        <input asp-for="endereco" type="text" class="form-control" value="@(Model?.endereco)">
                    </div>

                    <div class="col-md-6">
                        <label asp-for="logradouro" class="form-label fw-semibold">Rua</label>
                        <input asp-for="logradouro" type="text" class="form-control" value="@(Model?.logradouro)" maxlength="150">
                    </div>

                    <div class="col-md-3">
                        <label asp-for="numero" class="form-label fw-semibold">Número</label>
                        <input asp-for="numero" type="text" class="form-control" value="@(Model?.numero)" maxlength="5" pattern="^(\d+|s/n|S/N)$" title="Use apenas numeros ou s/n.">
                    </div>

                    <div class="col-md-5">
                        <label asp-for="cidade" class="form-label fw-semibold">Cidade</label>
                        <input asp-for="cidade" type="text" class="form-control" value="@(Model?.cidade)" maxlength="100">
                    </div>

                    <div class="col-md-2">
                        <label asp-for="estado" class="form-label fw-semibold">UF</label>
                        <select asp-for="estado" class="form-control">
                            <option value="">Selecione...</option>
                            <option value="AC">AC - Acre</option>
                            <option value="AL">AL - Alagoas</option>
                            <option value="AP">AP - Amapa</option>
                            <option value="AM">AM - Amazonas</option>
                            <option value="BA">BA - Bahia</option>
                            <option value="CE">CE - Ceara</option>
                            <option value="DF">DF - Distrito Federal</option>
                            <option value="ES">ES - Espirito Santo</option>
                            <option value="GO">GO - Goias</option>
                            <option value="MA">MA - Maranhao</option>
                            <option value="MT">MT - Mato Grosso</option>
                            <option value="MS">MS - Mato Grosso do Sul</option>
                            <option value="MG">MG - Minas Gerais</option>
                            <option value="PA">PA - Para</option>
                            <option value="PB">PB - Paraiba</option>
                            <option value="PR">PR - Parana</option>
                            <option value="PE">PE - Pernambuco</option>
                            <option value="PI">PI - Piaui</option>
                            <option value="RJ">RJ - Rio de Janeiro</option>
                            <option value="RN">RN - Rio Grande do Norte</option>
                            <option value="RS">RS - Rio Grande do Sul</option>
                            <option value="RO">RO - Rondonia</option>
                            <option value="RR">RR - Roraima</option>
                            <option value="SC">SC - Santa Catarina</option>
                            <option value="SP">SP - Sao Paulo</option>
                            <option value="SE">SE - Sergipe</option>
                            <option value="TO">TO - Tocantins</option>
                        </select>
                        <span asp-validation-for="estado" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="cep" class="form-label fw-semibold">CEP</label>
                        <input asp-for="cep" type="text" class="form-control" value="@(Model?.cep)" maxlength="9" inputmode="numeric" pattern="^[0-9\-]+$" title="Use apenas numeros ou hifen.">
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                    <button type="submit" class="btn-login">
                        <i class="fas fa-pencil-alt"></i> Salvar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function bindInputCleaner(selector, cleaner) {
            const input = document.querySelector(selector);
            if (!input) return;

            input.addEventListener('input', () => {
                const cleaned = cleaner(input.value);
                if (input.value !== cleaned) {
                    input.value = cleaned;
                }
            });
        }

        bindInputCleaner('[name="nome"]', value => value.replace(/\d/g, ''));
        bindInputCleaner('[name="telefone"]', value => value.replace(/[^0-9()\-\s]/g, ''));
        bindInputCleaner('[name="celular"]', value => value.replace(/[^0-9()\-\s]/g, ''));
        bindInputCleaner('[name="cep"]', value => value.replace(/[^0-9\-]/g, ''));
        bindInputCleaner('[name="numero"]', value => {
            if (/^\d/.test(value)) {
                return value.replace(/\D/g, '');
            }

            const cleaned = value.replace(/[^sSnN\/]/g, '');
            return /^s/i.test(cleaned) ? cleaned.slice(0, 3) : '';
        });
    </script>
}
