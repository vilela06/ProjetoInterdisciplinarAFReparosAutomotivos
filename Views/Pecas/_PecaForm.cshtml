@model AfReparosAutomotivos.Models.Pecas

<div class="container mt-5">
    <div class="card shadow-lg rounded-4 border-0">
        <div class="card-header text-white text-center rounded-top-4" style="background-color: #3b2e1a">
            <h3 class="mb-0">@ViewData["Title"]</h3>
        </div>
        <div class="card-body p-4">
            <form asp-action="@ViewContext.RouteData.Values["action"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="idPeca" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="nome" class="form-label fw-semibold"></label>
                        <input asp-for="nome" class="form-control" />
                        <span asp-validation-for="nome" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="qtdEsto" class="form-label fw-semibold"></label>
                        <input asp-for="qtdEsto" type="number" min="0" class="form-control" />
                        <span asp-validation-for="qtdEsto" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="valor" class="form-label fw-semibold"></label>
                        <input asp-for="valor" type="number" step="0.01" min="0" class="form-control" />
                        <span asp-validation-for="valor" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                    <button type="submit" class="btn-login">
                        <i class="fas fa-save"></i> Salvar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
