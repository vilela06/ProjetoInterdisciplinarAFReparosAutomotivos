@model IEnumerable<AfReparosAutomotivos.Models.Pecas>

@{
    ViewData["Title"] = "Pecas";
    var isAdmin = User.IsInRole("1");
    var pesquisa = (ViewBag.Pesquisa as string) ?? string.Empty;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-end gap-3 mb-3">
        <h3 class="mb-0">Peças</h3>
        <div class="d-flex flex-column align-items-end gap-2">
            @if (isAdmin)
            {
                <a asp-action="Create" class="btn btn-primary fw-semibold">Nova Peca</a>
            }
            <form asp-action="Index" method="get" class="af-admin-search">
                <input type="text"
                       name="pesquisa"
                       value="@pesquisa"
                       placeholder="Buscar por id ou nome" />
                <button type="submit" aria-label="Pesquisar peca">
                    <i class="fas fa-search"></i>
                </button>
                @if (!string.IsNullOrWhiteSpace(pesquisa))
                {
                    <a asp-action="Index" class="af-filter-clear" aria-label="Limpar busca">
                        <i class="fas fa-times"></i>
                    </a>
                }
            </form>
        </div>
    </div>

    <table class="table table-striped table-hover rounded-3 overflow-hidden shadow-sm">
        <thead>
            <tr class="table-primary">
                <th>@Html.DisplayNameFor(model => model.idPeca)</th>
                <th>@Html.DisplayNameFor(model => model.nome)</th>
                <th>@Html.DisplayNameFor(model => model.qtdEsto)</th>
                <th>@Html.DisplayNameFor(model => model.valor)</th>
                <th class="text-end">Acoes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.idPeca</td>
                    <td>@item.nome</td>
                    <td>@item.qtdEsto</td>
                    <td>@item.valor.ToString("C")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.idPeca" class="btn btn-sm" title="Ver">
                            <i class="fas fa-eye"></i>
                        </a>
                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@item.idPeca" class="btn btn-sm" title="Editar">
                                <i class="fas fa-pencil-alt"></i>
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
