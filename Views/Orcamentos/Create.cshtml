@model AfReparosAutomotivos.Models.OrcamentosViewModel

@{
    ViewData["Title"] = "Criar Orçamento";

    if (Model.ServicosAssociados == null || !Model.ServicosAssociados.Any())
    {
        Model.ServicosAssociados = new List<AfReparosAutomotivos.Models.ItemViewModel>
        {
            new AfReparosAutomotivos.Models.ItemViewModel { qtd = 1, qtdPeca = 1 }
        };
    }

    var br = new System.Globalization.CultureInfo("pt-BR");
    var servicosData = Model.ServicosDisponiveis.Select(s =>
    {
        var text = s.Text ?? "";
        var name = text.Split(" (R$")[0];
        var marker = "R$ ";
        var start = text.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        var price = 0m;
        if (start >= 0)
        {
            var raw = text[(start + marker.Length)..].Replace(")", "").Trim();
            decimal.TryParse(raw, System.Globalization.NumberStyles.Number, br, out price);
        }

        return new { value = s.Value, name, text = s.Text, price };
    });

    var pecasData = Model.PecasDisponiveis.Select(p =>
    {
        var text = p.Text ?? "";
        var marker = "R$ ";
        var start = text.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        var price = 0m;
        var stock = 0;
        if (start >= 0)
        {
            var raw = text[(start + marker.Length)..].Split(',')[0].Trim();
            decimal.TryParse(raw, System.Globalization.NumberStyles.Number, br, out price);
        }

        var stockMarker = "estoque ";
        var stockStart = text.IndexOf(stockMarker, StringComparison.OrdinalIgnoreCase);
        if (stockStart >= 0)
        {
            var rawStock = text[(stockStart + stockMarker.Length)..].Replace(")", "").Trim();
            int.TryParse(rawStock, out stock);
        }

        return new { value = p.Value, text = p.Text, price, stock };
    });

    Modal? mensagemModal = null;
    if (TempData["Mensagem"] is string jsonMessage)
    {
        mensagemModal = System.Text.Json.JsonSerializer.Deserialize<Modal>(jsonMessage);
    }
}

<form asp-action="Create" method="post" class="af-create-shell" id="orcamentoForm">
    <input type="hidden" asp-for="idCli" id="idCliente" />
    <input type="hidden" asp-for="idVeiculo" id="idVeiculo" />
    <input type="hidden" asp-for="EnderecoCli" id="EnderecoCli" />
    <input type="hidden" asp-for="dataCriacao" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
    <input type="hidden" asp-for="status" value="1" />

    <datalist id="servicos-list">
        @foreach (var servico in servicosData)
        {
            <option value="@servico.name">@servico.text</option>
        }
    </datalist>
    <datalist id="clientes-list"></datalist>
    <datalist id="veiculos-list"></datalist>

    <a asp-action="Index" class="af-create-close" aria-label="Fechar">
        <i class="fas fa-times"></i>
    </a>

    <section class="af-create-panel is-active" id="stepCadastro">
        <header class="af-create-header">
            <img src="~/images/logo-af-reparos.png" alt="AF Reparos Automotivos" />
            <h1>Criar Orçamento - Dados Cadastrais</h1>
        </header>

        <div class="af-create-grid af-create-grid-client">
            <label class="span-3">Nome:<span class="af-required">*</span><input asp-for="nome" id="nomeCliente" list="clientes-list" autocomplete="off" pattern="^[^\d]+$" title="Nao use numeros no nome." required /></label>
            <label>Telefone:<input asp-for="TelefoneCli" id="telefoneCliente" placeholder="(XX) XXXXX-XXXX" inputmode="tel" pattern="^[0-9()\-\s]*$" title="Use apenas numeros, espacos, parenteses ou hifen." /></label>
            <label>Celular:<span class="af-required">*</span><input asp-for="CelularCli" id="celularCliente" placeholder="(XX) XXXXX-XXXX" inputmode="tel" pattern="^[0-9()\-\s]+$" title="Use apenas numeros, espacos, parenteses ou hifen." required /></label>
            <label>Documento:<span class="af-required">*</span><input asp-for="DocumentoCli" id="documentoCliente" maxlength="14" required /></label>
            <label class="span-2">E-mail:<span class="af-required">*</span><input asp-for="EmailCli" id="emailCliente" type="email" required /></label>

            <label class="span-3">Rua:<span class="af-required">*</span><input id="ruaCliente" required /></label>
            <label>Nº:<span class="af-required">*</span><input id="numeroCliente" pattern="^(\d+|s/n|S/N)$" title="Use apenas numeros ou s/n." required /></label>
            <label class="span-2">Cidade:<span class="af-required">*</span><input id="cidadeCliente" required /></label>
            <label>UF:<span class="af-required">*</span>
                <select id="ufCliente" required>
                    <option value="">Selecione...</option>
                    <option value="AC">AC - Acre</option>
                    <option value="AL">AL - Alagoas</option>
                    <option value="AP">AP - Amapa</option>
                    <option value="AM">AM - Amazonas</option>
                    <option value="BA">BA - Bahia</option>
                    <option value="CE">CE - Ceara</option>
                    <option value="DF">DF - Distrito Federal</option>
                    <option value="ES">ES - Espirito Santo</option>
                    <option value="GO">GO - Goias</option>
                    <option value="MA">MA - Maranhao</option>
                    <option value="MT">MT - Mato Grosso</option>
                    <option value="MS">MS - Mato Grosso do Sul</option>
                    <option value="MG">MG - Minas Gerais</option>
                    <option value="PA">PA - Para</option>
                    <option value="PB">PB - Paraiba</option>
                    <option value="PR">PR - Parana</option>
                    <option value="PE">PE - Pernambuco</option>
                    <option value="PI">PI - Piaui</option>
                    <option value="RJ">RJ - Rio de Janeiro</option>
                    <option value="RN">RN - Rio Grande do Norte</option>
                    <option value="RS">RS - Rio Grande do Sul</option>
                    <option value="RO">RO - Rondonia</option>
                    <option value="RR">RR - Roraima</option>
                    <option value="SC">SC - Santa Catarina</option>
                    <option value="SP">SP - Sao Paulo</option>
                    <option value="SE">SE - Sergipe</option>
                    <option value="TO">TO - Tocantins</option>
                </select>
            </label>
            <label>CEP:<span class="af-required">*</span><input id="cepCliente" maxlength="9" inputmode="numeric" pattern="^[0-9\-]+$" title="Use apenas numeros ou hifen." required /></label>
        </div>

        <div class="af-create-footer af-create-footer-end">
            <button type="button" class="af-create-next" id="goServico">
                Próximo <i class="fas fa-arrow-right"></i>
            </button>
        </div>
    </section>

    <section class="af-create-panel" id="stepServico">
        <header class="af-create-header">
            <img src="~/images/logo-af-reparos.png" alt="AF Reparos Automotivos" />
            <h1>Criar Orçamento - Ordem de Serviço</h1>
        </header>

        <div class="af-create-grid af-create-grid-service">
            <label>Placa:<span class="af-required">*</span><input asp-for="Placa" id="placaVeiculo" list="veiculos-list" autocomplete="off" maxlength="7" required /></label>
            <label>Marca:<span class="af-required">*</span><input asp-for="Marca" id="marcaVeiculo" required /></label>
            <label>Modelo:<span class="af-required">*</span><input asp-for="Modelo" id="modeloVeiculo" required /></label>
            <label>Cor:<span class="af-required">*</span><input asp-for="Cor" id="corVeiculo" maxlength="20" required /></label>
            <label>Ano:<span class="af-required">*</span><input asp-for="Ano" id="anoVeiculo" type="number" min="1886" max="9999" required /></label>
            <label>Forma de pagamento:<span class="af-required">*</span>
                <select asp-for="formaPagamento" required>
                    <option value="">Selecione...</option>
                    <option value="Dinheiro">Dinheiro</option>
                    <option value="Pix">Pix</option>
                    <option value="Cartao de debito">Cartao de debito</option>
                    <option value="Cartao de credito">Cartao de credito</option>
                </select>
            </label>
            <label>Parcelas:<span class="af-required">*</span>
                <select asp-for="parcelas" required>
                    <option value="1">A vista</option>
                    @for (var parcela = 2; parcela <= 12; parcela++)
                    {
                        <option value="@parcela">@parcela x</option>
                    }
                </select>
            </label>
        </div>

        <div class="af-service-line" id="servicos-container">
            @for (int j = 0; j < Model.ServicosAssociados.Count; j++)
            {
                <div class="af-service-item" data-service-index="@j">
                    <div class="af-service-toggles">
                        <label class="af-toggle is-locked"><input type="checkbox" checked disabled /> Serviço</label>
                        <label class="af-toggle"><input type="checkbox" data-toggle-piece /> Peça</label>
                        <button type="button" class="af-remove-service" data-remove-service title="Remover servico">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>

                    <label class="af-service-description">Serviço<span class="af-required">*</span>
                        <input asp-for="ServicosAssociados[j].novoServicoDescricao" list="servicos-list" maxlength="50" required data-service-name data-total-field />
                        <input asp-for="ServicosAssociados[j].idServico" type="hidden" value="0" data-service-id />
                    </label>
                    <label>Funcionário<span class="af-required">*</span>
                        <select asp-for="ServicosAssociados[j].funcionarioId" asp-items="@Model.FuncionariosDisponiveis" required>
                            <option value="">Selecione...</option>
                        </select>
                    </label>
                    <label>Qtd.<span class="af-required">*</span><input asp-for="ServicosAssociados[j].qtd" type="number" min="1" required data-total-field /></label>
                    <label>Valor<span class="af-required">*</span><input asp-for="ServicosAssociados[j].preco" type="number" step="0.01" min="0" required data-service-price data-total-field /></label>

                    <div class="af-piece-row">
                        <label class="af-piece-field">Peça<span class="af-required">*</span>
                            <select asp-for="ServicosAssociados[j].pecaId" asp-items="@Model.PecasDisponiveis" data-piece-select data-total-field>
                                <option value="">Selecione a peça...</option>
                            </select>
                        </label>
                        <label class="af-piece-field">Qtd. peça<span class="af-required">*</span><input asp-for="ServicosAssociados[j].qtdPeca" type="number" min="1" value="1" data-piece-qty data-total-field /></label>
                        <label class="af-piece-field">Valor peça<span class="af-required">*</span><input asp-for="ServicosAssociados[j].valorPeca" type="number" step="0.01" min="0" value="0" readonly data-piece-price data-total-field /></label>
                    </div>

                    <div class="af-adjust-row">
                        <label>Taxa
                            <input type="text" inputmode="decimal" placeholder="0" data-tax-display data-total-field />
                        </label>
                        <label>Desconto
                            <input type="text" inputmode="decimal" placeholder="0" data-discount-display data-total-field />
                        </label>
                        <label>Subtotal <input type="text" value="R$ 0,00" readonly data-line-subtotal /></label>
                    </div>

                    <input type="hidden" asp-for="ServicosAssociados[j].desconto" value="0" data-discount-value />
                    <input type="hidden" asp-for="ServicosAssociados[j].taxa" value="0" data-tax-value />
                    <input type="hidden" asp-for="ServicosAssociados[j].observacao" value="" />
                    <input type="hidden" asp-for="ServicosAssociados[j].data_entrega" />
                </div>
            }
        </div>

        <div class="af-add-service-row">
            <button type="button" class="af-create-add-svc" id="btnAdicionarServico">
                <i class="fas fa-plus"></i> Adicionar serviÃ§o
            </button>
        </div>

        <div class="af-create-footer">
            <button type="button" class="af-create-back" id="goCadastro">
                <i class="fas fa-arrow-left"></i>
            </button>
            <div class="af-footer-spacer"></div>
            <div class="af-create-total">
                <span>Total</span>
                <input type="text" id="orcamentoTotal" value="R$ 0,00" readonly />
            </div>
            <div class="af-create-submit-stack">
            <button type="submit" class="af-create-save">
                <i class="fas fa-check"></i> Salvar
            </button>
            </div>
        </div>
    </section>
</form>

@if (mensagemModal != null)
{
    <partial name="_Modal" model="mensagemModal" />
}

@section Scripts
{
    <script>
        const servicosDisponiveisOptionsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(servicosData));
        const funcionariosDisponiveisOptionsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FuncionariosDisponiveis.Select(f => new { value = f.Value, text = f.Text })));
        const pecasDisponiveisOptionsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(pecasData));
        let serviceIndexCounter = @Model.ServicosAssociados.Count;
        let clientesEncontrados = [];
        let veiculosEncontrados = [];
        let clienteSearchTimer;
        let veiculoSearchTimer;

        const money = new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' });
        const normalize = value => (value || '').trim().toLocaleLowerCase('pt-BR');

        function ensureServiceDatalist(line) {
            const serviceName = line.querySelector('[data-service-name]');
            if (!serviceName) return;

            let datalistId = serviceName.getAttribute('list');
            if (!datalistId || datalistId === 'servicos-list') {
                datalistId = `servicos-list-${window.crypto?.randomUUID?.() || Math.random().toString(36).slice(2)}`;
                const datalist = document.createElement('datalist');
                datalist.id = datalistId;
                serviceName.after(datalist);
                serviceName.setAttribute('list', datalistId);
                return;
            }

            if (!document.getElementById(datalistId)) {
                const datalist = document.createElement('datalist');
                datalist.id = datalistId;
                serviceName.after(datalist);
            }
        }

        function getSelectedService(line) {
            const serviceName = line.querySelector('[data-service-name]');
            const serviceId = line.querySelector('[data-service-id]')?.value;

            return servicosDisponiveisOptionsData.find(item => item.value === serviceId && serviceId !== '0')
                || servicosDisponiveisOptionsData.find(item => normalize(item.name) === normalize(serviceName?.value));
        }

        function updateServiceSuggestions() {
            const lines = [...document.querySelectorAll('.af-service-item')];
            const selectedByLine = new Map(lines.map(line => [line, getSelectedService(line)?.value || '']));
            const selectedIds = new Set([...selectedByLine.values()].filter(Boolean));

            lines.forEach(line => {
                ensureServiceDatalist(line);

                const serviceName = line.querySelector('[data-service-name]');
                const datalist = document.getElementById(serviceName?.getAttribute('list'));
                if (!datalist) return;

                const currentServiceId = selectedByLine.get(line);
                datalist.innerHTML = '';
                servicosDisponiveisOptionsData
                    .filter(item => !selectedIds.has(item.value) || item.value === currentServiceId)
                    .forEach(item => {
                        const option = document.createElement('option');
                        option.value = item.name;
                        option.textContent = item.text || item.name;
                        datalist.appendChild(option);
                    });
            });
        }

        function bindInputCleaner(id, cleaner) {
            const input = document.getElementById(id);
            if (!input) return;

            input.addEventListener('input', () => {
                const cleaned = cleaner(input.value);
                if (input.value !== cleaned) {
                    input.value = cleaned;
                }
            });
        }

        bindInputCleaner('nomeCliente', value => value.replace(/\d/g, ''));
        bindInputCleaner('telefoneCliente', value => value.replace(/[^0-9()\-\s]/g, ''));
        bindInputCleaner('celularCliente', value => value.replace(/[^0-9()\-\s]/g, ''));
        bindInputCleaner('cepCliente', value => value.replace(/[^0-9\-]/g, ''));
        bindInputCleaner('numeroCliente', value => {
            if (/^\d/.test(value)) {
                return value.replace(/\D/g, '');
            }

            const cleaned = value.replace(/[^sSnN\/]/g, '');
            return /^s/i.test(cleaned) ? cleaned.slice(0, 3) : '';
        });

        function setOptions(datalistId, items, getValue, getText) {
            const datalist = document.getElementById(datalistId);
            datalist.innerHTML = items
                .map(item => `<option value="${getValue(item)}">${getText(item)}</option>`)
                .join('');
        }

        async function buscarJson(url) {
            const resposta = await fetch(url, { headers: { 'Accept': 'application/json' } });
            return resposta.ok ? await resposta.json() : [];
        }

        function preencherCliente(cliente) {
            document.getElementById('idCliente').value = cliente.id || '';
            document.getElementById('nomeCliente').value = cliente.nome || '';
            document.getElementById('telefoneCliente').value = cliente.telefone || '';
            document.getElementById('celularCliente').value = cliente.celular || '';
            document.getElementById('documentoCliente').value = cliente.documento || '';
            document.getElementById('emailCliente').value = cliente.email || '';
            document.getElementById('ruaCliente').value = cliente.logradouro || '';
            document.getElementById('numeroCliente').value = cliente.numero || '';
            document.getElementById('cidadeCliente').value = cliente.cidade || '';
            document.getElementById('ufCliente').value = cliente.estado || '';
            document.getElementById('cepCliente').value = cliente.cep || '';
            document.getElementById('idVeiculo').value = '';
            document.getElementById('placaVeiculo').value = '';
            document.getElementById('marcaVeiculo').value = '';
            document.getElementById('modeloVeiculo').value = '';
            document.getElementById('corVeiculo').value = '';
            document.getElementById('anoVeiculo').value = '';
            composeEndereco();
        }

        function preencherVeiculo(veiculo) {
            document.getElementById('idVeiculo').value = veiculo.id || '';
            document.getElementById('placaVeiculo').value = veiculo.placa || '';
            document.getElementById('marcaVeiculo').value = veiculo.marca || '';
            document.getElementById('modeloVeiculo').value = veiculo.modelo || '';
            document.getElementById('corVeiculo').value = veiculo.cor || '';
            document.getElementById('anoVeiculo').value = veiculo.ano || '';
        }

        function composeEndereco() {
            const rua = document.getElementById('ruaCliente').value;
            const numero = document.getElementById('numeroCliente').value;
            const cidade = document.getElementById('cidadeCliente').value;
            const uf = document.getElementById('ufCliente').value;
            const cep = document.getElementById('cepCliente').value;
            document.getElementById('EnderecoCli').value = [rua, numero, cidade, uf, cep].filter(Boolean).join(', ');
        }

        function optionHtml(items, emptyText) {
            return [`<option value="">${emptyText}</option>`]
                .concat(items.map(item => `<option value="${item.value}">${item.text}</option>`))
                .join('');
        }

        function parseAdjustment(value, baseValue) {
            const raw = (value || '').trim().replace(',', '.');
            if (!raw) {
                return 0;
            }

            const numeric = Number(raw.replace('%', ''));
            if (!Number.isFinite(numeric) || numeric < 0) {
                return 0;
            }

            return raw.includes('%') ? baseValue * (numeric / 100) : numeric;
        }

        function updateLine(line) {
            const serviceName = line.querySelector('[data-service-name]');
            const serviceId = line.querySelector('[data-service-id]');
            const servicePrice = line.querySelector('[data-service-price]');
            const pieceSelect = line.querySelector('[data-piece-select]');
            const piecePrice = line.querySelector('[data-piece-price]');
            const pieceQty = line.querySelector('[data-piece-qty]');
            const pieceRow = line.querySelector('.af-piece-row');
            const pieceMode = line.querySelector('[data-toggle-piece]')?.checked;

            const selectedService = servicosDisponiveisOptionsData.find(item => normalize(item.name) === normalize(serviceName?.value));
            if (selectedService) {
                if (serviceId.value !== selectedService.value) {
                    serviceId.value = selectedService.value;
                    servicePrice.value = Number(selectedService.price || 0).toFixed(2);
                }
            } else if (serviceId) {
                serviceId.value = '0';
            }

            updateServiceSuggestions();

            if (pieceRow) {
                pieceRow.classList.toggle('is-open', !!pieceMode);
                pieceRow.querySelectorAll('select, input').forEach(field => {
                    field.required = !!pieceMode;
                });
            }

            const selectedPiece = pecasDisponiveisOptionsData.find(item => item.value === pieceSelect?.value);
            if (selectedPiece && piecePrice) {
                piecePrice.value = Number(selectedPiece.price || 0).toFixed(2);
                if (pieceQty) {
                    pieceQty.max = selectedPiece.stock || 1;
                    if (Number(pieceQty.value || 0) > Number(pieceQty.max)) {
                        pieceQty.value = pieceQty.max;
                    }
                }
            } else if (piecePrice) {
                piecePrice.value = '0.00';
                if (pieceQty) {
                    pieceQty.removeAttribute('max');
                }
            }

            updateTotal();
        }

        function calculateLineTotal(line) {
            const qtd = Math.max(1, Number(line.querySelector('[name$=".qtd"]')?.value || 1));
            const servicePrice = Number(line.querySelector('[data-service-price]')?.value || 0);
            const piecePrice = Number(line.querySelector('[data-piece-price]')?.value || 0);
            const pieceQty = Number(line.querySelector('[data-piece-qty]')?.value || 0);
            const serviceBase = servicePrice * qtd;
            const pieceBase = piecePrice * pieceQty;
            const taxValue = parseAdjustment(line.querySelector('[data-tax-display]')?.value, serviceBase);
            const discountValue = parseAdjustment(line.querySelector('[data-discount-display]')?.value, serviceBase);
            const subtotal = Math.max(0, serviceBase + pieceBase + taxValue - discountValue);

            const taxHidden = line.querySelector('[data-tax-value]');
            const discountHidden = line.querySelector('[data-discount-value]');
            const subtotalField = line.querySelector('[data-line-subtotal]');
            if (taxHidden) taxHidden.value = taxValue.toFixed(2);
            if (discountHidden) discountHidden.value = discountValue.toFixed(2);
            if (subtotalField) subtotalField.value = money.format(subtotal);

            return subtotal;
        }

        function updateTotal() {
            let total = 0;
            document.querySelectorAll('.af-service-item').forEach(line => {
                total += calculateLineTotal(line);
            });

            document.getElementById('orcamentoTotal').value = money.format(total);
        }

        function bindLine(line) {
            ensureServiceDatalist(line);

            line.querySelectorAll('[data-total-field], [data-toggle-piece]').forEach(element => {
                element.addEventListener('input', () => updateLine(line));
                element.addEventListener('change', () => updateLine(line));
            });

            line.querySelector('[data-remove-service]')?.addEventListener('click', () => {
                const lines = document.querySelectorAll('.af-service-item');
                if (lines.length <= 1) {
                    line.querySelectorAll('input:not([type="hidden"]), select').forEach(field => {
                        if (field.matches('[data-service-name], select')) {
                            field.value = '';
                        } else if (field.matches('[name$=".qtd"], [name$=".qtdPeca"]')) {
                            field.value = '1';
                        } else {
                            field.value = '0';
                        }
                    });
                    line.querySelector('[data-service-id]').value = '0';
                    updateLine(line);
                    return;
                }

                line.remove();
                reindexServiceLines();
                updateTotal();
                updateServiceSuggestions();
            });

            updateLine(line);
        }

        function reindexServiceLines() {
            document.querySelectorAll('.af-service-item').forEach((line, index) => {
                line.dataset.serviceIndex = index;
                line.querySelectorAll('[name]').forEach(field => {
                    field.name = field.name.replace(/ServicosAssociados\[\d+\]/, `ServicosAssociados[${index}]`);
                });
                line.querySelectorAll('[id]').forEach(field => {
                    field.id = field.id.replace(/ServicosAssociados_\d+__/, `ServicosAssociados_${index}__`);
                });
            });
            serviceIndexCounter = document.querySelectorAll('.af-service-item').length;
        }

        document.getElementById('goServico').addEventListener('click', () => {
            const requiredFields = document.querySelectorAll('#stepCadastro [required]');
            if (![...requiredFields].every(field => field.reportValidity())) {
                return;
            }

            composeEndereco();
            document.getElementById('stepCadastro').classList.remove('is-active');
            document.getElementById('stepServico').classList.add('is-active');
        });

        document.getElementById('goCadastro').addEventListener('click', () => {
            document.getElementById('stepServico').classList.remove('is-active');
            document.getElementById('stepCadastro').classList.add('is-active');
        });

        document.getElementById('orcamentoForm').addEventListener('submit', () => {
            composeEndereco();
            updateTotal();
        });

        document.getElementById('nomeCliente').addEventListener('input', event => {
            const termo = event.target.value.trim();
            const selecionado = clientesEncontrados.find(cliente => normalize(cliente.nome) === normalize(termo));
            if (selecionado) {
                preencherCliente(selecionado);
                return;
            }

            document.getElementById('idCliente').value = '';
            clearTimeout(clienteSearchTimer);
            if (termo.length < 2) {
                setOptions('clientes-list', [], item => item.nome, item => item.nome);
                return;
            }

            clienteSearchTimer = setTimeout(async () => {
                clientesEncontrados = await buscarJson(`/Orcamentos/BuscarClientes?termo=${encodeURIComponent(termo)}`);
                setOptions(
                    'clientes-list',
                    clientesEncontrados,
                    cliente => cliente.nome,
                    cliente => `${cliente.documento || ''} - ${cliente.celular || ''}`);
            }, 250);
        });

        document.getElementById('placaVeiculo').addEventListener('input', event => {
            const termo = event.target.value.trim();
            const selecionado = veiculosEncontrados.find(veiculo => normalize(veiculo.placa) === normalize(termo));
            if (selecionado) {
                preencherVeiculo(selecionado);
                return;
            }

            document.getElementById('idVeiculo').value = '';
            clearTimeout(veiculoSearchTimer);
            const clienteId = Number(document.getElementById('idCliente').value || 0);
            if (clienteId <= 0 || termo.length < 1) {
                setOptions('veiculos-list', [], item => item.placa, item => item.placa);
                return;
            }

            veiculoSearchTimer = setTimeout(async () => {
                veiculosEncontrados = await buscarJson(`/Orcamentos/BuscarVeiculosCliente?clienteId=${clienteId}&termo=${encodeURIComponent(termo)}`);
                setOptions(
                    'veiculos-list',
                    veiculosEncontrados,
                    veiculo => veiculo.placa,
                    veiculo => `${veiculo.marca || ''} ${veiculo.modelo || ''} ${veiculo.cor || ''} ${veiculo.ano || ''}`);
            }, 250);
        });

        function buildServiceLineHtml(index) {
            return `
                <div class="af-service-item" data-service-index="${index}">
                    <div class="af-service-toggles">
                        <label class="af-toggle is-locked"><input type="checkbox" checked disabled /> Serviço</label>
                        <label class="af-toggle"><input type="checkbox" data-toggle-piece /> Peça</label>
                        <button type="button" class="af-remove-service" data-remove-service title="Remover servico">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                    <label class="af-service-description">Serviço<span class="af-required">*</span>
                        <input name="ServicosAssociados[${index}].novoServicoDescricao" list="servicos-list" maxlength="50" required data-service-name data-total-field />
                        <input name="ServicosAssociados[${index}].idServico" type="hidden" value="0" data-service-id />
                    </label>
                    <label>Funcionário<span class="af-required">*</span>
                        <select name="ServicosAssociados[${index}].funcionarioId" required>${optionHtml(funcionariosDisponiveisOptionsData, 'Selecione...')}</select>
                    </label>
                    <label>Qtd.<span class="af-required">*</span><input name="ServicosAssociados[${index}].qtd" type="number" min="1" value="1" required data-total-field /></label>
                    <label>Valor<span class="af-required">*</span><input name="ServicosAssociados[${index}].preco" type="number" step="0.01" min="0" required data-service-price data-total-field /></label>
                    <div class="af-piece-row">
                        <label class="af-piece-field">Peça<span class="af-required">*</span><select name="ServicosAssociados[${index}].pecaId" data-piece-select data-total-field>${optionHtml(pecasDisponiveisOptionsData, 'Selecione a peça...')}</select></label>
                        <label class="af-piece-field">Qtd. peça<span class="af-required">*</span><input name="ServicosAssociados[${index}].qtdPeca" type="number" min="1" value="1" data-piece-qty data-total-field /></label>
                        <label class="af-piece-field">Valor peça<span class="af-required">*</span><input name="ServicosAssociados[${index}].valorPeca" type="number" step="0.01" min="0" value="0" readonly data-piece-price data-total-field /></label>
                    </div>
                    <div class="af-adjust-row">
                        <label>Taxa<input type="text" inputmode="decimal" placeholder="%" data-tax-display data-total-field /></label>
                        <label>Desconto<input type="text" inputmode="decimal" placeholder="0" data-discount-display data-total-field /></label>
                        <label>Subtotal <input type="text" value="R$ 0,00" readonly data-line-subtotal /></label>
                    </div>
                    <input type="hidden" name="ServicosAssociados[${index}].desconto" value="0" data-discount-value />
                    <input type="hidden" name="ServicosAssociados[${index}].taxa" value="0" data-tax-value />
                    <input type="hidden" name="ServicosAssociados[${index}].observacao" value="" />
                    <input type="hidden" name="ServicosAssociados[${index}].data_entrega" value="" />
                </div>`;
        }

        document.getElementById('btnAdicionarServico').addEventListener('click', () => {
            document.getElementById('servicos-container').insertAdjacentHTML('beforeend', buildServiceLineHtml(serviceIndexCounter));
            bindLine(document.querySelector(`[data-service-index="${serviceIndexCounter}"]`));
            serviceIndexCounter++;
        });

        function restoreEnderecoFromHidden() {
            const endereco = document.getElementById('EnderecoCli')?.value || '';
            if (!endereco || document.getElementById('ruaCliente').value) {
                return;
            }

            const partes = endereco.split(',').map(parte => parte.trim());
            document.getElementById('ruaCliente').value = partes[0] || '';
            document.getElementById('numeroCliente').value = partes[1] || '';
            document.getElementById('cidadeCliente').value = partes[2] || '';
            document.getElementById('ufCliente').value = partes[3] || '';
            document.getElementById('cepCliente').value = partes[4] || '';
        }

        document.querySelectorAll('.af-service-item').forEach(bindLine);
        restoreEnderecoFromHidden();

        @if (mensagemModal != null)
        {
            <text>
                document.addEventListener('DOMContentLoaded', function () {
                    showGenericModal('@mensagemModal.Id');
                });
            </text>
        }
    </script>
}
