@model AfReparosAutomotivos.Models.OrcamentosViewModel

@{
    ViewData["Title"] = "Criar Orçamento";

    if (Model.ServicosAssociados == null || !Model.ServicosAssociados.Any())
    {
        Model.ServicosAssociados = new List<AfReparosAutomotivos.Models.ItemViewModel>
        {
            new AfReparosAutomotivos.Models.ItemViewModel { qtd = 1, qtdPeca = 1 }
        };
    }

    var br = new System.Globalization.CultureInfo("pt-BR");
    var servicosData = Model.ServicosDisponiveis.Select(s =>
    {
        var text = s.Text ?? "";
        var name = text.Split(" (R$")[0];
        var marker = "R$ ";
        var start = text.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        var price = 0m;
        if (start >= 0)
        {
            var raw = text[(start + marker.Length)..].Replace(")", "").Trim();
            decimal.TryParse(raw, System.Globalization.NumberStyles.Number, br, out price);
        }

        return new { value = s.Value, name, text = s.Text, price };
    });

    var pecasData = Model.PecasDisponiveis.Select(p =>
    {
        var text = p.Text ?? "";
        var marker = "R$ ";
        var start = text.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        var price = 0m;
        if (start >= 0)
        {
            var raw = text[(start + marker.Length)..].Split(',')[0].Trim();
            decimal.TryParse(raw, System.Globalization.NumberStyles.Number, br, out price);
        }

        return new { value = p.Value, text = p.Text, price };
    });
}

<form asp-action="Create" method="post" class="af-create-shell" id="orcamentoForm">
    <input type="hidden" asp-for="idCli" id="idCliente" />
    <input type="hidden" asp-for="idVeiculo" id="idVeiculo" />
    <input type="hidden" asp-for="EnderecoCli" id="EnderecoCli" />
    <input type="hidden" asp-for="dataCriacao" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
    <input type="hidden" asp-for="status" value="1" />
    <input type="hidden" asp-for="formaPagamento" value="" />
    <input type="hidden" asp-for="parcelas" value="1" />

    <datalist id="servicos-list">
        @foreach (var servico in servicosData)
        {
            <option value="@servico.name">@servico.text</option>
        }
    </datalist>

    <a asp-action="Index" class="af-create-close" aria-label="Fechar">
        <i class="fas fa-times"></i>
    </a>

    <section class="af-create-panel is-active" id="stepCadastro">
        <header class="af-create-header">
            <img src="~/images/logo-af-reparos.png" alt="AF Reparos Automotivos" />
            <h1>Criar orçamento - Dados cadastrais</h1>
        </header>

        <div class="af-create-grid af-create-grid-client">
            <label class="span-3">Nome:<span class="af-required">*</span><input asp-for="nome" id="nomeCliente" required /></label>
            <label>Telefone:<span class="af-required">*</span><input asp-for="TelefoneCli" id="telefoneCliente" placeholder="(XX) XXXXX-XXXX" required /></label>
            <label>Celular:<span class="af-required">*</span><input asp-for="CelularCli" id="celularCliente" placeholder="(XX) XXXXX-XXXX" required /></label>
            <label>Documento:<span class="af-required">*</span><input asp-for="DocumentoCli" id="documentoCliente" maxlength="14" required /></label>

            <label class="span-3">Rua:<input id="ruaCliente" /></label>
            <label>Nº:<input id="numeroCliente" /></label>
            <label class="span-2">Cidade:<input id="cidadeCliente" /></label>
            <label>UF:<input id="ufCliente" maxlength="2" /></label>
            <label>CEP:<input id="cepCliente" maxlength="9" /></label>
        </div>

        <button type="button" class="af-create-next" id="goServico" aria-label="Proxima etapa">
            <i class="fas fa-arrow-right"></i>
        </button>
    </section>

    <section class="af-create-panel" id="stepServico">
        <header class="af-create-header">
            <img src="~/images/logo-af-reparos.png" alt="AF Reparos Automotivos" />
            <h1>Criar orçamento - Ordem de serviço</h1>
        </header>

        <div class="af-create-grid af-create-grid-service">
            <label>Placa:<span class="af-required">*</span><input asp-for="Placa" id="placaVeiculo" maxlength="7" required /></label>
            <label>Marca:<span class="af-required">*</span><input asp-for="Marca" id="marcaVeiculo" required /></label>
            <label>Modelo:<span class="af-required">*</span><input asp-for="Modelo" id="modeloVeiculo" required /></label>
            <label>Cor:<input /></label>
            <label>Ano:<input /></label>
        </div>

        <div class="af-service-line" id="servicos-container">
            @for (int j = 0; j < Model.ServicosAssociados.Count; j++)
            {
                <div class="af-service-item" data-service-index="@j">
                    <div class="af-service-toggles">
                        <label class="af-toggle is-locked"><input type="checkbox" checked disabled /> Serviço</label>
                        <label class="af-toggle"><input type="checkbox" data-toggle-piece /> Peça</label>
                    </div>

                    <label>Qtd.<span class="af-required">*</span><input asp-for="ServicosAssociados[j].qtd" type="number" min="1" required data-total-field /></label>
                    <label class="af-service-description">Serviço<span class="af-required">*</span>
                        <input asp-for="ServicosAssociados[j].novoServicoDescricao" list="servicos-list" maxlength="50" required data-service-name data-total-field />
                        <input asp-for="ServicosAssociados[j].idServico" type="hidden" value="0" data-service-id />
                    </label>
                    <label>Funcionário<span class="af-required">*</span>
                        <select asp-for="ServicosAssociados[j].funcionarioId" asp-items="@Model.FuncionariosDisponiveis" required>
                            <option value="">Selecione...</option>
                        </select>
                    </label>
                    <label>Valor<span class="af-required">*</span><input asp-for="ServicosAssociados[j].preco" type="number" step="0.01" min="0" required data-service-price data-total-field /></label>

                    <div class="af-piece-row">
                        <label>Peça
                            <select asp-for="ServicosAssociados[j].pecaId" asp-items="@Model.PecasDisponiveis" data-piece-select data-total-field>
                                <option value="">Selecione a peça...</option>
                            </select>
                        </label>
                        <label>Qtd. peça<input asp-for="ServicosAssociados[j].qtdPeca" type="number" min="1" value="1" data-piece-qty data-total-field /></label>
                        <label>Valor peça<input asp-for="ServicosAssociados[j].valorPeca" type="number" step="0.01" min="0" readonly data-piece-price data-total-field /></label>
                    </div>

                    <input type="hidden" asp-for="ServicosAssociados[j].desconto" value="0" />
                    <input type="hidden" asp-for="ServicosAssociados[j].taxa" value="0" />
                    <input type="hidden" asp-for="ServicosAssociados[j].observacao" value="" />
                    <input type="hidden" asp-for="ServicosAssociados[j].data_entrega" />
                </div>
            }
        </div>

        <div class="af-add-service-block">
            <span>Quais tipos de serviço?</span>
            <button type="button" id="btnAdicionarServico"><i class="fas fa-plus"></i> Adicionar</button>
        </div>

        <button type="button" class="af-create-back" id="goCadastro" aria-label="Voltar">
            <i class="fas fa-arrow-left"></i>
        </button>

        <div class="af-create-total">
            <span>Total</span>
            <input type="text" id="orcamentoTotal" value="R$ 0,00" readonly />
        </div>

        <div class="af-create-submit-actions">
            <button type="submit" name="acao" value="checar">
                <i class="fas fa-save"></i>
                <span>Salvar e Checar</span>
            </button>
            <button type="submit" name="acao" value="gerar">
                <i class="fas fa-check"></i>
                <span>Salvar e Gerar</span>
            </button>
        </div>
    </section>
</form>

@section Scripts
{
    <script>
        const servicosDisponiveisOptionsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(servicosData));
        const funcionariosDisponiveisOptionsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FuncionariosDisponiveis.Select(f => new { value = f.Value, text = f.Text })));
        const pecasDisponiveisOptionsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(pecasData));
        let serviceIndexCounter = @Model.ServicosAssociados.Count;

        const money = new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' });
        const normalize = value => (value || '').trim().toLocaleLowerCase('pt-BR');

        function composeEndereco() {
            const rua = document.getElementById('ruaCliente').value;
            const numero = document.getElementById('numeroCliente').value;
            const cidade = document.getElementById('cidadeCliente').value;
            const uf = document.getElementById('ufCliente').value;
            const cep = document.getElementById('cepCliente').value;
            document.getElementById('EnderecoCli').value = [rua, numero, cidade, uf, cep].filter(Boolean).join(', ');
        }

        function optionHtml(items, emptyText) {
            return [`<option value="">${emptyText}</option>`]
                .concat(items.map(item => `<option value="${item.value}">${item.text}</option>`))
                .join('');
        }

        function updateLine(line) {
            const serviceName = line.querySelector('[data-service-name]');
            const serviceId = line.querySelector('[data-service-id]');
            const servicePrice = line.querySelector('[data-service-price]');
            const pieceSelect = line.querySelector('[data-piece-select]');
            const piecePrice = line.querySelector('[data-piece-price]');
            const pieceRow = line.querySelector('.af-piece-row');
            const pieceMode = line.querySelector('[data-toggle-piece]')?.checked;

            const selectedService = servicosDisponiveisOptionsData.find(item => normalize(item.name) === normalize(serviceName?.value));
            if (selectedService) {
                serviceId.value = selectedService.value;
                servicePrice.value = Number(selectedService.price || 0).toFixed(2);
            } else if (serviceId) {
                serviceId.value = '0';
            }

            if (pieceRow) {
                pieceRow.classList.toggle('is-open', !!pieceMode);
            }

            const selectedPiece = pecasDisponiveisOptionsData.find(item => item.value === pieceSelect?.value);
            if (selectedPiece && piecePrice) {
                piecePrice.value = Number(selectedPiece.price || 0).toFixed(2);
            } else if (!pieceSelect?.value && piecePrice) {
                piecePrice.value = '';
            }

            updateTotal();
        }

        function updateTotal() {
            let total = 0;
            document.querySelectorAll('.af-service-item').forEach(line => {
                const qtd = Number(line.querySelector('[name$=".qtd"]')?.value || 0);
                const servicePrice = Number(line.querySelector('[data-service-price]')?.value || 0);
                const piecePrice = Number(line.querySelector('[data-piece-price]')?.value || 0);
                const pieceQty = Number(line.querySelector('[data-piece-qty]')?.value || 0);
                total += (servicePrice * qtd) + (piecePrice * pieceQty);
            });

            document.getElementById('orcamentoTotal').value = money.format(total);
        }

        function bindLine(line) {
            line.querySelectorAll('[data-total-field], [data-toggle-piece]').forEach(element => {
                element.addEventListener('input', () => updateLine(line));
                element.addEventListener('change', () => updateLine(line));
            });
            updateLine(line);
        }

        document.getElementById('goServico').addEventListener('click', () => {
            const requiredFields = document.querySelectorAll('#stepCadastro [required]');
            if (![...requiredFields].every(field => field.reportValidity())) {
                return;
            }

            composeEndereco();
            document.getElementById('stepCadastro').classList.remove('is-active');
            document.getElementById('stepServico').classList.add('is-active');
        });

        document.getElementById('goCadastro').addEventListener('click', () => {
            document.getElementById('stepServico').classList.remove('is-active');
            document.getElementById('stepCadastro').classList.add('is-active');
        });

        document.getElementById('orcamentoForm').addEventListener('submit', composeEndereco);

        document.getElementById('btnAdicionarServico').addEventListener('click', () => {
            const html = `
                <div class="af-service-item" data-service-index="${serviceIndexCounter}">
                    <div class="af-service-toggles">
                        <label class="af-toggle is-locked"><input type="checkbox" checked disabled /> Serviço</label>
                        <label class="af-toggle"><input type="checkbox" data-toggle-piece /> Peça</label>
                    </div>
                    <label>Qtd.<span class="af-required">*</span><input name="ServicosAssociados[${serviceIndexCounter}].qtd" type="number" min="1" value="1" required data-total-field /></label>
                    <label class="af-service-description">Serviço<span class="af-required">*</span>
                        <input name="ServicosAssociados[${serviceIndexCounter}].novoServicoDescricao" list="servicos-list" maxlength="50" required data-service-name data-total-field />
                        <input name="ServicosAssociados[${serviceIndexCounter}].idServico" type="hidden" value="0" data-service-id />
                    </label>
                    <label>Funcionário<span class="af-required">*</span>
                        <select name="ServicosAssociados[${serviceIndexCounter}].funcionarioId" required>${optionHtml(funcionariosDisponiveisOptionsData, 'Selecione...')}</select>
                    </label>
                    <label>Valor<span class="af-required">*</span><input name="ServicosAssociados[${serviceIndexCounter}].preco" type="number" step="0.01" min="0" required data-service-price data-total-field /></label>
                    <div class="af-piece-row">
                        <label>Peça<select name="ServicosAssociados[${serviceIndexCounter}].pecaId" data-piece-select data-total-field>${optionHtml(pecasDisponiveisOptionsData, 'Selecione a peça...')}</select></label>
                        <label>Qtd. peça<input name="ServicosAssociados[${serviceIndexCounter}].qtdPeca" type="number" min="1" value="1" data-piece-qty data-total-field /></label>
                        <label>Valor peça<input name="ServicosAssociados[${serviceIndexCounter}].valorPeca" type="number" step="0.01" min="0" readonly data-piece-price data-total-field /></label>
                    </div>
                    <input type="hidden" name="ServicosAssociados[${serviceIndexCounter}].desconto" value="0" />
                    <input type="hidden" name="ServicosAssociados[${serviceIndexCounter}].taxa" value="0" />
                    <input type="hidden" name="ServicosAssociados[${serviceIndexCounter}].observacao" value="" />
                    <input type="hidden" name="ServicosAssociados[${serviceIndexCounter}].data_entrega" value="" />
                </div>`;

            document.getElementById('servicos-container').insertAdjacentHTML('beforeend', html);
            bindLine(document.querySelector(`[data-service-index="${serviceIndexCounter}"]`));
            serviceIndexCounter++;
        });

        document.querySelectorAll('.af-service-item').forEach(bindLine);
    </script>
}
