@model IEnumerable<AfReparosAutomotivos.Models.OrcamentosViewModel>

@{
    ViewData["Title"] = "Lista de Orcamentos";
    var currentBusca = Context.Request.Query["busca"].ToString();
    var currentStatus = Context.Request.Query["statusId"].ToString();
}

<section class="af-admin-budget-screen">
    @if (TempData["OrcamentoMensagem"] is string mensagem)
    {
        <div class="alert alert-warning mx-auto" style="max-width: 920px;" role="alert">@mensagem</div>
    }

    <div class="af-budget-table-wrap d-flex justify-content-between align-items-center gap-3 mb-3">
        <h3 class="mb-0">Orçamentos</h3>

        <div class="af-admin-toolbar">
            <form method="get" asp-action="Index" class="af-admin-search">
                @if (!string.IsNullOrWhiteSpace(currentStatus))
                {
                    <input type="hidden" name="statusId" value="@currentStatus" />
                }
                <input type="text" name="busca" value="@currentBusca" placeholder="Pesquisar nome, id ou data..." />
                <button type="submit" aria-label="Pesquisar">
                    <i class="fas fa-search"></i>
                </button>
            </form>
        </div>
    </div>

    <div class="af-budget-content">
        <aside class="af-status-filter-card" aria-label="Filtrar por status">
            <div class="af-status-filter-title">Filtro status</div>
            <a asp-action="Index" asp-route-busca="@currentBusca" class="@(string.IsNullOrWhiteSpace(currentStatus) ? "is-active" : "")">
                <span class="af-status-dot af-status-white"></span> Todos
            </a>
            <a asp-action="Index" asp-route-busca="@currentBusca" asp-route-statusId="1" class="@(currentStatus == "1" ? "is-active" : "")">
                <span class="af-status-dot af-status-gray"></span> Em analise
            </a>
            <a asp-action="Index" asp-route-busca="@currentBusca" asp-route-statusId="2" class="@(currentStatus == "2" ? "is-active" : "")">
                <span class="af-status-dot af-status-green"></span> Aprovado
            </a>
            <a asp-action="Index" asp-route-busca="@currentBusca" asp-route-statusId="3" class="@(currentStatus == "3" ? "is-active" : "")">
                <span class="af-status-dot af-status-red"></span> Recusado
            </a>
            <a asp-action="Index" asp-route-busca="@currentBusca" asp-route-statusId="4" class="@(currentStatus == "4" ? "is-active" : "")">
                <span class="af-status-dot af-status-orange"></span> Sendo executado
            </a>
            <a asp-action="Index" asp-route-busca="@currentBusca" asp-route-statusId="5" class="@(currentStatus == "5" ? "is-active" : "")">
                <span class="af-status-dot af-status-blue"></span> Finalizado
            </a>
        </aside>

        <div class="af-budget-table-wrap">
            <div class="af-budget-table-header d-flex justify-content-between align-items-center gap-3 mb-3">
                <h3 class="mb-0">Orçamentos</h3>

                <div class="af-admin-toolbar">
                    <form method="get" asp-action="Index" class="af-admin-search">
                        @if (!string.IsNullOrWhiteSpace(currentStatus))
                        {
                            <input type="hidden" name="statusId" value="@currentStatus" />
                        }
                        <input type="text" name="busca" value="@currentBusca" placeholder="Pesquisar nome, id ou data..." />
                        <button type="submit" aria-label="Pesquisar">
                            <i class="fas fa-search"></i>
                        </button>
                    </form>
                </div>
            </div>

            <table class="table table-striped table-hover rounded-3 overflow-hidden shadow-sm">
                <thead>
                    <tr class="table-primary">
                        <th>Status</th>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Data</th>
                        <th>Total</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var statusClass = item.status switch
                            {
                                1 => "af-status-gray",
                                2 => "af-status-green",
                                3 => "af-status-red",
                                4 => "af-status-orange",
                                5 => "af-status-blue",
                                _ => "af-status-gray"
                            };
                            var bloqueiaEdicao = item.status == 5;
                            var bloqueiaExclusao = item.status is 2 or 4 or 5;

                            <tr>
                                <td><span class="af-status-dot @statusClass"></span></td>
                                <td>@item.idOrcamento</td>
                                <td>@item.nome</td>
                                <td>@item.dataCriacao.ToString("dd-MM-yyyy")</td>
                                <td>@item.total.ToString("C2")</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.idOrcamento" class="btn btn-sm" title="Ver">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="GerarPdf" asp-route-id="@item.idOrcamento" class="btn btn-sm" title="Imprimir">
                                        <i class="fas fa-print"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm" data-action-menu="@item.idOrcamento" aria-label="Mais acoes">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>

                                    <div class="af-action-popover" id="action-menu-@item.idOrcamento">
                                        @if (bloqueiaEdicao)
                                        {
                                            <span class="af-action-choice af-action-disabled" title="Orcamento finalizado nao pode ser alterado">
                                                <i class="fas fa-lock"></i> Alterar
                                            </span>
                                        }
                                        else
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.idOrcamento" class="af-action-choice af-action-edit">
                                                <i class="fas fa-pencil-alt"></i> Alterar
                                            </a>
                                        }

                                        @if (bloqueiaExclusao)
                                        {
                                            <span class="af-action-choice af-action-disabled" title="Este status nao permite exclusao">
                                                <i class="fas fa-lock"></i> Excluir
                                            </span>
                                        }
                                        else
                                        {
                                            <button type="button" class="af-action-choice af-action-delete" data-delete-open="@item.idOrcamento">
                                                <i class="fas fa-trash-alt"></i> Excluir
                                            </button>
                                        }
                                    </div>

                                    <div class="af-delete-modal" id="delete-modal-@item.idOrcamento" aria-hidden="true">
                                        <div class="af-delete-card">
                                            <div class="af-delete-message">
                                                <i class="fas fa-trash-alt"></i>
                                                <strong>Deseja excluir<br />esse item?</strong>
                                            </div>
                                            <div class="af-delete-actions">
                                                <form asp-action="Delete" asp-route-id="@item.idOrcamento" method="post">
                                                    <button type="submit">Sim</button>
                                                </form>
                                                <button type="button" data-delete-close="@item.idOrcamento">Nao</button>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Nenhum orcamento encontrado.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <a asp-action="Create" class="af-floating-add" aria-label="Criar orcamento">
        <i class="fas fa-plus"></i>
    </a>
</section>

@section Scripts {
    <script>
        function closeActionMenus(exceptId) {
            document.querySelectorAll('.af-action-popover').forEach(menu => {
                if (!exceptId || menu.id !== `action-menu-${exceptId}`) {
                    menu.classList.remove('is-open');
                }
            });
        }

        function positionActionMenu(button, menu) {
            const rect = button.getBoundingClientRect();
            const spacing = 8;

            menu.style.visibility = 'hidden';
            menu.classList.add('is-open');

            const menuRect = menu.getBoundingClientRect();
            const availableBelow = window.innerHeight - rect.bottom;
            const top = availableBelow >= menuRect.height + spacing
                ? rect.bottom + spacing
                : Math.max(spacing, rect.top - menuRect.height - spacing);

            const left = Math.min(
                window.innerWidth - menuRect.width - spacing,
                Math.max(spacing, rect.right - menuRect.width)
            );

            menu.style.top = `${top}px`;
            menu.style.left = `${left}px`;
            menu.style.visibility = '';
        }

        document.querySelectorAll('[data-action-menu]').forEach(button => {
            button.addEventListener('click', (event) => {
                event.stopPropagation();
                const id = button.getAttribute('data-action-menu');
                const menu = document.getElementById(`action-menu-${id}`);
                const willOpen = !menu?.classList.contains('is-open');

                closeActionMenus(id);

                if (menu && willOpen) {
                    positionActionMenu(button, menu);
                } else {
                    menu?.classList.remove('is-open');
                }
            });
        });

        document.querySelectorAll('[data-delete-open]').forEach(button => {
            button.addEventListener('click', (event) => {
                event.stopPropagation();
                closeActionMenus();
                document.getElementById(`delete-modal-${button.getAttribute('data-delete-open')}`)?.classList.add('is-open');
            });
        });

        document.querySelectorAll('[data-delete-close]').forEach(button => {
            button.addEventListener('click', () => {
                document.getElementById(`delete-modal-${button.getAttribute('data-delete-close')}`)?.classList.remove('is-open');
            });
        });

        document.addEventListener('click', () => closeActionMenus());

        window.addEventListener('scroll', () => closeActionMenus(), true);
        window.addEventListener('resize', () => closeActionMenus());
    </script>
}
